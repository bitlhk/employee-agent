# Local MCP endpoint
CREDENTIAL_WORKSPACE_MCP_HOST=127.0.0.1
CREDENTIAL_WORKSPACE_MCP_PORT=17898

# Credential upstream MCP service. Do not commit real tokens.
CRED_UPSTREAM_URL=http://1.92.221.155:8005
CRED_UPSTREAM_TOKEN=

# JiuwenSwarm service roots. The adapter resolves:
#   <service_root>/agent_jiuwen_<lgj-id>/agent/jiuwenclaw_workspace
CREDENTIAL_JIUWEN_SERVICE_ROOTS=/root/.jiuwenswarm/service_linggan_shanghai,/root/.jiuwenswarm/service_linggan

# Safety limits
CREDENTIAL_ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.webp,.bmp,.tif,.tiff,.pdf
CREDENTIAL_MAX_FILE_BYTES=10485760
CREDENTIAL_IMAGE_MAX_WIDTH=1280
CREDENTIAL_IMAGE_JPEG_QUALITY=82

# Upstream tool mapping. Adjust after confirming the provider tool names.
CREDENTIAL_UPSTREAM_CLASSIFY_TOOL=classification
CREDENTIAL_UPSTREAM_EXTRACT_TOOL=credential-extractor
CREDENTIAL_UPSTREAM_PROMPT_TOOL=credential-prompt-generator
CREDENTIAL_UPSTREAM_IMAGE_FIELD=images
CREDENTIAL_UPSTREAM_IMAGE_FORMAT=base64
