{
  "version": "2026-06-18-v2",
  "principles": [
    "用户默认只获得 basic 通用能力，不默认暴露金融专业、中队专区和业务 MCP。",
    "岗位是权限与能力分配的最小业务单元：industry + role + skills + mcpServers + model + runtime。",
    "skill 和 MCP 可动态增减；岗位模板只保存基线组合，后台可为单个用户叠加例外。",
    "用户侧选择岗位身份，后台侧决定 runtime、模型、MCP 白名单和专区可见范围。",
    "公共数据 MCP 按岗位最小可用开放，内部业务 MCP 必须按岗位和数据权限授权。"
  ],
  "schema": {
    "defaultRole": "general-assistant",
    "permissionProfiles": [
      "plus",
      "internal"
    ],
    "runtimes": [
      "jiuwenswarm",
      "openclaw"
    ],
    "origins": [
      "opensource",
      "finance",
      "squad"
    ],
    "roleStatus": [
      "mvp",
      "disabled"
    ],
    "visibleZones": [
      "opensource",
      "finance",
      "squad"
    ],
    "notes": [
      "defaultSkills 为岗位默认安装并激活的 Skill；optionalSkills 为岗位可见但默认不自动安装的 Skill。",
      "mcpServers 为 P2 岗位默认允许暴露给 runtime 的 MCP 白名单；mcpTools 仅作未来子工具级授权参考，不进入 P2 grants。",
      "permissionProfile 只表示沙箱/协作权限档，不表示业务岗位。",
      "dataScope 当前仅为说明字段，真实数据权限由 MCP 服务按 agent/user context 强制。"
    ]
  },
  "runtimePolicy": {
    "defaultRuntime": "jiuwenswarm",
    "fallbackRuntime": "openclaw",
    "selection": "用户选择岗位，不直接选择底层 runtime；新用户默认在 JiuwenSwarm 上创建，OpenClaw 保留为兼容和回退 runtime。"
  },
