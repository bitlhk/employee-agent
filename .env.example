# ╔══════════════════════════════════════════════════════════════════════╗
# ║  岗位智能体 环境变量配置                                      ║
# ║  标注 [必填] 的项部署前必须修改，否则服务无法启动或存在安全风险            ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ── 基础配置 ──────────────────────────────────────────────────────────
PORT=5180
# Docker 默认仅监听宿主机回环地址，由 nginx/WAF 反代；确需直连时再显式设置 0.0.0.0。
APP_BIND_IP=127.0.0.1

# ── 访问方式 ──────────────────────────────────────────────────────────
# 本机访问: http://localhost:5180  (CORS_ORIGIN 和 FRONTEND_URL 设为 http://localhost:5180, COOKIE_DOMAIN 留空)
# 内网访问: http://192.168.x.x:5180
# 域名访问: https://your-domain.com
# 同时作为浏览器 Cookie 写请求的 CSRF Origin 白名单；多个地址用逗号分隔。
CORS_ORIGIN=http://localhost:5180
FRONTEND_URL=http://localhost:5180
# WebSocket 可用前端源，多个地址用逗号分隔；默认回退 CORS_ORIGIN/FRONTEND_URL。
WS_ALLOWED_ORIGINS=http://localhost:5180
# 对外可访问 URL。微信/协作通知等外部链接会优先使用它；未设置则回退 FRONTEND_URL。
PUBLIC_BASE_URL=http://localhost:5180
# Cookie 跨子域共享（本机/内网部署留空，域名部署设 .example.com）
COOKIE_DOMAIN=

# ── 飞书频道 ──────────────────────────────────────────────────────────
# 用于 EA 通过“灵感智能体”飞书应用主动发送协作提醒。
# 与 JiuwenSwarm 飞书 Bot 使用同一套应用即可；不要提交真实值。
LINGGAN_FEISHU_APP_ID=
LINGGAN_FEISHU_APP_SECRET=
LINGGAN_FEISHU_DOMAIN=feishu

# JiuwenSwarm 定时任务回调（可选；默认使用 INTERNAL_API_KEY 和本机地址）
# WORKFORCE_AGENT_JIUWEN_CALLBACK_URL=http://127.0.0.1:5180/api/internal/jiuwen/callback
# WORKFORCE_AGENT_JIUWEN_WEBHOOK_TOKEN=

# ── 数据库 [必填] ────────────────────────────────────────────────────
# Docker Compose 部署: 使用下面的默认值即可（MySQL 容器自动创建）
# 手动部署: 改为你的 MySQL 地址
DATABASE_URL=mysql://employee_agent:YOUR_STRONG_PASSWORD@db:3306/employee_agent

# Docker Compose 部署时需要设置：
# MYSQL_ROOT_PASSWORD=<MySQL root 强密码>
# MYSQL_DATABASE=employee_agent
# MYSQL_USER=employee_agent
# MYSQL_PASSWORD=<应用数据库用户密码，与 DATABASE_URL 中的密码一致>

# ── 认证 [必填] ──────────────────────────────────────────────────────
# setup.sh 会自动生成，也可手动: openssl rand -hex 32
JWT_SECRET=
# 登录会话默认 7 天，允许范围 15 分钟至 30 天。
SESSION_MAX_AGE_MS=604800000
# 建议使用独立 32 字节以上随机值；未设置时兼容性回退使用 JWT_SECRET 派生不同用途的密钥。
CREDENTIAL_ENCRYPTION_KEY=
# disabled/optional/required。生产机安装 ClamAV 后建议 required；required 时扫描不可用会拒绝上传。
UPLOAD_ANTIVIRUS_MODE=disabled
# Production: set required only after clamd and freshclam are healthy.
# CLAMAV_COMMAND=clamdscan
# CLAMAV_TIMEOUT_MS=30000
# 外部 OAuth 可选配置；全部留空时使用本地账号登录，不影响启动。
# 启用时前端统一从 /api/oauth/start 发起，state 由后端生成并校验。
# OAUTH_SERVER_URL=https://oauth-api.example.com
# OAUTH_PORTAL_URL=https://oauth.example.com
# OAUTH_CALLBACK_URL=https://your-domain.com/api/oauth/callback

# ── 安全 [必填] ──────────────────────────────────────────────────────
# 租户隔离密钥，setup.sh 自动生成
# 生产环境必填；不设置将拒绝启动
TENANT_SECRET=
INTERNAL_API_KEY=
# 聊天审计默认只记录长度和 HMAC；建议使用独立随机密钥，也可留空回退 INTERNAL_API_KEY/JWT_SECRET。
LOG_MESSAGE_HMAC_KEY=
# 仅故障诊断时临时设为 true；会写入经过脱敏且最多 160 字的消息预览。
LOG_MESSAGE_PREVIEW_ENABLED=false
# 仅管理员确需投递到私网 HTTPS Webhook 时填写精确主机名/IP，多个值用逗号分隔。
NOTIFY_WEBHOOK_PRIVATE_HOST_ALLOWLIST=
# 普通运行日志默认保留 30 天，安全审计和执行明细默认保留 730 天。
APP_LOG_RETENTION_DAYS=30
AUDIT_LOG_RETENTION_DAYS=730
# MCP/运行时审计写入令牌。默认复用 INTERNAL_API_KEY；如需独立轮换可单独设置。
EA_AUDIT_INGEST_TOKEN=
# 远端 file-service 访问令牌。部署远端业务 Agent 文件服务时必填；不要提交真实值。
FILE_SERVICE_TOKEN=
# 独立部署默认可关闭邮箱验证码；配置 SMTP 后建议改为 true
EMAIL_VERIFICATION_REQUIRED=false
# SMTP 587 默认校验证书。仅在测试自签名证书时显式打开下列开关之一。
SMTP_ALLOW_SELF_SIGNED=false
# SMTP_TLS_REJECT_UNAUTHORIZED=true

# ── Agent Runtime ─────────────────────────────────────────────────────
# 默认岗位运行时为 JiuwenSwarm。安装并配置 JiuwenSwarm 后，将下面两项改为 true。
# 未启用时平台可以启动和完成管理员配置，但不会静默回退到 OpenClaw。
JIUWENSWARM_PROVISION_ENABLED=false
JIUWENCLAW_RUNTIME_ENABLED=false
JIUWENCLAW_CHAT_TRANSPORT=gateway
# “自动”模式的目标模型，可填写模型 ID、alias 或 model_name；留空使用 JiuwenSwarm 默认模型。
JIUWEN_AUTO_TARGET_MODEL=
CLAW_PROVISION_MODE=mock
CLAW_CHAT_MODE=mock
# OpenClaw 是可选兼容运行时，当前不作为开源版本默认运行时。
# 旧 OpenClaw 远程管理仅支持 SSH key/agent，不支持密码命令行。
# CLAW_REMOTE_HOST=
# CLAW_REMOTE_USER=root
# CLAW_REMOTE_SSH_KEY=
# CLAW_REMOTE_KNOWN_HOSTS_FILE=
# 同机部署时填写运行岗位智能体平台/OpenClaw 的系统用户 home 目录。
# 例如 root 部署填 /root，ubuntu 部署填 /home/ubuntu。
# 也兼容直接填写 .openclaw 目录，例如 /home/ubuntu/.openclaw。
CLAW_OPENCLAW_HOME=/home/ubuntu
CLAW_REMOTE_OPENCLAW_HOME=/home/ubuntu
CLAW_GATEWAY_PORT=18789
# Gateway 认证 Token [必填] — 必须与 openclaw.json 里的 gateway.auth.token 一致
# setup.sh 会自动生成并同步到 OpenClaw 配置
CLAW_GATEWAY_TOKEN=
# 远端 Gateway 地址（单机部署保持 127.0.0.1）
CLAW_REMOTE_HOST=127.0.0.1

# Hermes profiles path; either /home/ubuntu/.hermes or /home/ubuntu/.hermes/profiles is accepted.
# HERMES_HOME=/home/ubuntu/.hermes

# ── 业务 Agent（可选）────────────────────────────────────────────────
# 远端 Agent Gateway 地址（如果业务 agent 部署在其他机器）
# CLAW_REMOTE_GATEWAY_HOST=127.0.0.1
# Hermes Agent skills 目录（Hermes 式业务 agent 需要）
# HERMES_SKILLS_ROOT=/home/ubuntu/.hermes/skills
# 内置金融演示 Preset 默认关闭。只有在你明确部署了对应业务工具链时才打开。
ENABLE_BUILTIN_BUSINESS_AGENT_PRESETS=false

# ── 实验工作台（可选）───────────────────────────────────────────────
# 开启后仅 admin 可访问 /task-workbench-lab；ALLOW_USER_IDS 留空表示所有 admin。
TASK_WORKBENCH_LAB_ENABLED=false
TASK_WORKBENCH_LAB_ALLOW_USER_IDS=
TASK_WORKBENCH_LAB_MAX_AGENTS=3
# TASK_WORKBENCH_LAB_KILL_FILE=/tmp/lingxia-task-workbench-lab.disabled

# ── 平台记忆（Hermes 式策展记忆）─────────────────────────────────────
# 自动从对话中提取用户偏好，需要 DeepSeek API Key
MEMORY_ENABLED=true
MEMORY_EXTRACT_INTERVAL=5
MEMORY_CHAR_LIMIT=2200
MEMORY_USER_CHAR_LIMIT=1375
DEEPSEEK_API_KEY=

# ── EA 助手模型（可选）───────────────────────────────────────────────
# 用于历史会话标题、轻量摘要、简单路由等 EA 平台自身任务，不影响主对话模型。
# 华为 MaaS OpenAI-compatible 推荐 base_url: https://api.modelarts-maas.com/openai/v1
EA_ASSISTANT_MODEL_BASE_URL=https://api.modelarts-maas.com/openai/v1
EA_ASSISTANT_MODEL_NAME=openpangu-2.0-flash
EA_ASSISTANT_MODEL_PROVIDER=OpenAI
EA_ASSISTANT_MODEL_DISABLE_THINKING=true
EA_ASSISTANT_MODEL_TIMEOUT_MS=8000
# 可直接填 MaaS token，也可通过 EA_ASSISTANT_MODEL_ENV_PATH 复用外部 .env 中的 API_KEY。
EA_ASSISTANT_MODEL_API_KEY=
EA_ASSISTANT_MODEL_ENV_PATH=

# ── 外部 Agent / MCP Endpoint 安全（可选）────────────────────────────
# 默认禁止业务 Agent endpoint 指向 localhost、内网地址和云 metadata 地址。
# 如企业内网确需访问指定 Agent，可优先使用白名单；仅受控私有部署才建议开启全局放行。
EA_AGENT_ENDPOINT_ALLOWLIST=
EA_ALLOW_PRIVATE_AGENT_ENDPOINTS=false

# ── 岗位智能体路由 ─────────────────────────────────────────────────────────
# 域名部署时设置，本机/内网部署可留空
# LINGGAN_CLAW_BASE_DOMAIN=demo.your-domain.com
# LINGGAN_CLAW_ENTRY_SCHEME=https
# DEMO_ROUTE_DOMAIN=demo.your-domain.com
# SITE_DOMAIN=www.your-domain.com

# ── 沙箱执行（Docker 隔离，可选）──────────────────────────────────────
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_MEMORY=256m
SANDBOX_CPUS=0.5
SANDBOX_PIDS_LIMIT=50
SANDBOX_TMPFS_SIZE=50m
SANDBOX_EXEC_TIMEOUT_MS=10000
SANDBOX_MAX_OUTPUT_BYTES=65536
SANDBOX_MAX_GLOBAL=5
SANDBOX_MAX_PER_USER=2
